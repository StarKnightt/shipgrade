# Shipgrade environment variables. ALL OPTIONAL.
# The app runs fully on its deterministic heuristic engine with no keys set.

# Enable an AI-enhanced verdict + a shareable "roast" line.
# Any OpenAI-compatible Chat Completions endpoint works.
OPENAI_API_KEY=

# Override the model (defaults to gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

# Override the base URL for OpenAI-compatible providers.
# OPENAI_BASE_URL=https://api.openai.com/v1
